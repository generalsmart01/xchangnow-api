# XchangeNow API — environment template
# Copy to .env and fill in. Never commit .env (it's gitignored).

# ─── Runtime ─────────────────────────────────────────────
NODE_ENV=development
PORT=3000

# Public URL of this API (used to build links in outgoing emails).
# Locally: http://localhost:3000  (or whatever your PORT is)
# Production: https://xchangnow-api.onrender.com
APP_URL=http://localhost:3000

# ─── Database ────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/xchangenow_dev?schema=public

# ─── JWT ─────────────────────────────────────────────────
# Generate via: node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
JWT_ACCESS_SECRET=replace-with-32+-random-chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_SECRET=different-32+-random-chars
JWT_REFRESH_EXPIRES_IN=7d

# ─── Passwords ───────────────────────────────────────────
BCRYPT_ROUNDS=12

# ─── SMTP (optional) ─────────────────────────────────────
# Leave UNSET to log emails to console (dev mode).
# Set ALL FOUR (HOST/PORT/USER/PASS) to enable real email delivery.
# Recommended dev provider: Mailtrap (free sandbox at mailtrap.io)
# Production providers: Resend, SendGrid, Mailgun, SES, Gmail SMTP w/ app password
# SMTP_HOST=sandbox.smtp.mailtrap.io
# SMTP_PORT=2525
# SMTP_USER=your-mailtrap-username
# SMTP_PASS=your-mailtrap-password
# EMAIL_FROM=XchangeNow <no-reply@xchangenow.com>
